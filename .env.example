# Telegram API Credentials (https://my.telegram.org)
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash_here

# PostgreSQL
DATABASE_URL=postgres://teledrive:teledrive@localhost:5432/teledrive?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-change-this-in-production

# Encryption key for Telegram sessions (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Allowed phone numbers (comma-separated, e.g. +628123456,+628765432)
ALLOWED_PHONES=+628123456789

# Server
PORT=8080
